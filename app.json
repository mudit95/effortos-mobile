{
  "expo": {
    "name": "EffortOS",
    "slug": "effortos",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "effortos",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0f"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.effortos.mobile",
      "infoPlist": {
        "UIBackgroundModes": []
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0f"
      },
      "package": "app.effortos.mobile",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-keep-awake"
    ],
    "extra": {
      "supabaseUrl": "https://muqavvntwzwzbxuxefre.supabase.co",
      "supabaseAnonKey": "sb_publishable_vy1CHkBMrKJ2FSY4-ODvIg_aFUcygLK"
    }
  }
}
